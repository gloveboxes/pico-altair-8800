{
  "cmake.generator": "Ninja",
  "cmake.useCMakePresets": "always",
  "cmake.configurePreset": "pico-release",
  "cmake.buildPreset": "pico-release",
  "cmake.buildDirectory": "${workspaceFolder}/build/pico",
  "cmake.configureOnOpen": true,
  "files.associations": {
    "stdio.h": "c",
    "list": "cpp",
    "__verbose_abort": "c",
    "cstdio": "c"
  }
}